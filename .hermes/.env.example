# Hermes Agent environment variables
# Copy to ~/.hermes/.env and fill in real values.
# These are referenced from custom_providers in config.yaml.

# LLM Gateway (oai-gateway + llm-gateway providers)
LLM_GATEWAY_BASE_URL=
LLM_GATEWAY_API_KEY=

# LLM Broker (llm-broker provider)
LLM_BROKER_BASE_URL=
LLM_BROKER_API_KEY=
