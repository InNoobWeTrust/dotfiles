{
  "$schema": "https://app.kilo.ai/config.json",
  "small_model": "kilo/kilo-auto/free",
  "instructions": [
    "~/.agents/instructions/agent-instructions.md",
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
  },
  "agent": {
    "title": {
      "model": "kilo/kilo-auto/free",
    },
    "summary": {
      "model": "kilo/kilo-auto/free",
    },
    "compaction": {
      "model": "kilo/kilo-auto/free",
    },
    "general": {
      "mode": "primary",
      "hidden": true,
      "model": "kilo/kilo-auto/free",
    },
    "explore": {
      "mode": "primary",
      "hidden": true,
      "model": "kilo/kilo-auto/free",
    },
    "build": {
      "mode": "primary",
      "hidden": true,
      "model": "kilo/kilo-auto/free",
    },
    "orchestrator": {
      "hidden": true,
      "model": "kilo/kilo-auto/free",
    },
    "ask": {
      "model": "kilo/kilo-auto/free",
    },
    "plan": {
      "model": "oai-gateway/openai/chatbot-5.4",
      "options": {
        "reasoningEffort": "high",
      },
    },
    "code": {
      "model": "llm-gateway/kCode",
      "options": {
        "reasoningEffort": "high",
      },
    },
    "debug": {
      "model": "github-copilot/claude-sonnet-4.6",
      "options": {
        "reasoningEffort": "high",
      },
    },
    "swarm-node": {
      "mode": "primary",
      "hidden": true,
      "description": "Single-purpose analysis node for swarm pipelines. CLI/direct invocation only — not for interactive use or task tool.",
      "prompt": "## Core Rules\\n\\n1. Follow the persona instructions provided in the user message exactly.\\n2. Provide thorough, well-structured output. Include all relevant information, insights, and recommendations.\\n3. Use web search (WebFetch) when the persona explicitly requests it.\\n4. Be specific and detailed — the synthesizer extracts key points and builds consensus from multiple node outputs.\\n5. Never modify files or run shell commands. Read and web fetch are permitted; write/bash are always denied.\\n6. If given a file path in the prompt, read that file to obtain the input document.",
      "permission": {
        "task": "deny",
        "lsp": "allow",
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "deny",
        "skill": "allow",
        "question": "deny",
        "webfetch": "allow",
        "todowrite": "deny",
        "websearch": "allow",
        "doom_loop": "deny",
        "codesearch": "allow",
        "external_directory": "deny",
      },
    },
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--browser-url=http://localhost:19222"
      ],
      "enabled": true
    },
  },
  "provider": {
    "llm-broker": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "${LLM_BROKER_BASE_URL}",
      },
      "env": [
        "LLM_BROKER_API_KEY",
      ],
      "models": {
        // ── Anthropic Claude ─────────────────────────────────────────
        // claude-sonnet-4-5: SKIP — superseded by 4.6 at same price
        // claude-3-x series: SKIP — all retired early 2026
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 [balanced]",
          "limit": {
            "context": 900000,
            "output": 16000
          },
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5 [fast]",
          "limit": {
            "context": 180000,
            "output": 8192
          },
        },
        // ── DeepSeek ─────────────────────────────────────────────────
        // deepseek-v3.2-thinking: SKIP — redundant with r1
        // deepseek-v3.1: SKIP — higher cost, worse perf than v3.2
        // deepseek-v3: SKIP — superseded
        // deepseek-chat: SKIP — deprecated alias, unpredictable broker routing
        // Note: v4 not available via this broker; v3.2 is best available
        "deepseek-v3.2": {
          "name": "DeepSeek V3.2 [balanced]",
          "limit": {
            "context": 65536,
            "output": 8192
          },
        },
        // ── OpenAI GPT ────────────────────────────────────────────────
        // gpt-5.3-codex: SKIP — no official source; likely fake broker ID
        // gpt-5.2: SKIP — redundant between 5.1 and 5.4
        // gpt-5, gpt-5-mini: SKIP — superseded by 5.1+
        // gpt-4.1, gpt-4.1-mini, gpt-4.1-nano, gpt-4o, gpt-4o-mini: SKIP — RETIRED Feb 13 2026
        "gpt-5.4": {
          "name": "GPT-5.4 [balanced]",
          "limit": {
            "context": 1000000,
            "output": 16384
          },
        },
        // ── xAI Grok ──────────────────────────────────────────────────
        // grok-4, grok-4-fast: SKIP — superseded by grok-4.1 series
        // grok-3, grok-3-mini, grok-3-reasoner: SKIP — two generations behind / deprecated
        "grok-4.1": {
          "name": "Grok 4.1 [flagship]",
          "limit": {
            "context": 256000,
            "output": 16384
          },
        },
        "grok-4.1-fast": {
          "name": "Grok 4.1 Fast [fast]",
          "limit": {
            "context": 1800000,
            "output": 8192
          },
        },
        // ── Alibaba Qwen ──────────────────────────────────────────────
        // qwen3.5 series not available via this broker; qwen3 is best available
        // qwen3-235b-a22b, qwen3-32b: SKIP — qwen3-max covers general use
        // qwen-plus-latest, qwen-max-latest, qwen-turbo, qwen-flash: SKIP — older commercial line, superseded by qwen3
        "qwen3-max": {
          "name": "Qwen3 Max [balanced]",
          "limit": {
            "context": 128000,
            "output": 8192
          },
        },
      },
    },
    "oai-gateway": {
      "npm": "@ai-sdk/openai",
      "options": {
        "baseURL": "${LLM_GATEWAY_BASE_URL}",
      },
      "env": [
        "LLM_GATEWAY_API_KEY"
      ],
      "models": {
        "openai/chatbot-5.5": {
          "limit": {
            "context": 1000000,
            "output": 16384
          },
        },
        "openai/chatbot-5.4": {
          "limit": {
            "context": 1000000,
            "output": 16384
          },
        },
      }
    },
    "llm-gateway": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "${LLM_GATEWAY_BASE_URL}",
      },
      "env": [
        "LLM_GATEWAY_API_KEY"
      ],
      "models": {
        "kCode": {
          "limit": {
            "context": 128000,
            "output": 32768
          },
        },
        "qwen/qwen3.6-plus": {
          "limit": {
            "context": 128000,
            "output": 8192
          },
        },
      }
    }
  },
  "permission": {
    "bash": {
      "git status *": "allow",
      "git log *": "allow",
      "git fetch *": "allow",
      "git ls-files *": "allow",
      "git show *": "allow",
      "git diff *": "allow",
      "echo *": "allow",
      "ls *": "allow",
      "swarminator *": "allow",
      "kilo *": "allow",
      "find *": "allow",
      "sort *": "allow",
      "wc *": "allow",
      "wait *": "allow",
      "which *": "allow",
      "gemini *": "allow",
      "head *": "allow",
      "cat *": "allow",
      "jq *": "allow",
      "$SHELL *": "allow",
      "sleep *": "allow",
      "timeout *": "allow",
      "grep *": "allow",
      "basename *": "allow",
      "rm *": "ask",
      "uuidgen *": "allow",
      "tr *": "allow",
      "cargo check *": "allow",
      "cargo test *": "allow",
      "command *": "allow",
      "rustfmt *": "allow",
      "rustc *": "allow",
      "cargo info *": "allow",
      "cargo doc *": "allow",
      "tail *": "allow",
      "rg *": "allow",
      "printf *": "allow",
      "git remote -v *": "allow",
      "git init *": "allow",
      "brew list *": "allow",
      "git check-ignore *": "allow",
      "go mod *": "allow",
      "go get *": "allow",
      "go doc *": "allow",
      "go list *": "allow",
      "go build *": "allow",
      "claude *": "allow",
      "codex *": "allow",
      "go run *": "allow",
      "go test *": "allow",
      "git branch *": "allow",
      "curl *": "allow",
      "test *": "allow",
      "readlink *": "allow",
      "gtimeout *": "allow",
      "stat *": "allow",
      "chmod *": "allow",
      "npm list *": "allow",
      "kill *": "ask",
      "gh repo list *": "allow",
      "git -C *": "ask",
      "gh auth status *": "allow",
      "gh release list *": "allow",
      "xargs *": "ask",
      "gofmt *": "allow",
      "go generate *": "allow",
      "gh run list *": "allow",
      "gh run watch *": "allow",
      "brew tap-info *": "allow",
      "brew info *": "allow",
      "brew update *": "allow",
      "brew outdated *": "allow",
      "git checkout *": "allow",
      "git pull *": "allow",
      "brew upgrade *": "allow",
      "gh run view *": "allow",
      "gh pr view *": "allow",
      "go vet *": "allow",
    },
    "recall": {
      "search": "allow"
    },
    "external_directory": {
      "/tmp/*": "allow",
      "~/.agents/*": "allow",
      "~/.config/kilo/*": "allow",
    },
  },
}
