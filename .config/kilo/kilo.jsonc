{
  "$schema": "https://app.kilo.ai/config.json",
  "small_model": "kilo/kilo-auto/free",
  "instructions": [
    "~/.agents/instructions/agent-instructions.md",
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
  },
  "agent": {
    "title": {
      "model": "kilo/kilo-auto/free",
    },
    "summary": {
      "model": "kilo/kilo-auto/free",
    },
    //"compaction": {
    //  "model": "kilo/kilo-auto/free",
    //},
    "general": {
      "description": "Read-only general research. USE SPARINGLY: only for vague questions with no specialized subagent match. Prefer explore for codebase nav, plan for design, code for implementation, debug for bugs.",
      //"model": "github-copilot/claude-sonnet-4.5",
      //"model": "ink-gw/openai/chatgpt-5.4-mini",
      "model": "ink-gw/deepseek/deepseek-v4-pro",
    },
    "explore": {
      "description": "Can only use tools with no side-effect",
      "model": "github-copilot/claude-haiku-4.5",
      //"model": "ink-gw/openai/chatgpt-5.4-mini",
    },
    "orchestrator": {
      "description": "Deprecated workflow orchestrator for coordinating complex tasks by delegating to specialized agents",
      "model": "llm-agg/forbiddengun/glm",
    },
    "ask": {
      "description": "A knowledgeable technical assistant focused on answering questions without changing your codebase",
      "model": "kilo/kilo-auto/free",
    },
    "plan": {
      "mode": "all",
      "description": "System design, architecture decisions, technical planning, and implementation roadmaps. Use for: design docs, architecture, API contracts, data modeling, tech stack decisions, or planning complex features.",
      //"model": "github-copilot/gpt-5.4",
      //"model": "llm-agg/forbiddengun/glm-5.2",
      "model": "ink-gw/openai/chatbot-5.4",
    },
    "code": {
      "mode": "all",
      "description": "Writes, refactors, and debugs code. Use for: implementing features, fixing bugs, refactoring, writing tests, and any code-level work. Full tool access.",
      //"model": "github-copilot/claude-sonnet-4.5",
      "model": "ink-gw/deepseek/deepseek-v4-pro",
      //"model": "llm-agg/forbiddengun/deepseek",
      //"model": "llm-agg/forbiddengun/claude",
    },
    "debug": {
      "mode": "all",
      "description": "Systematic troubleshooting and root cause analysis. Use for: diagnosing test failures, CI/CD failures, runtime errors, performance issues, and hard-to-reproduce bugs.",
      //"model": "github-copilot/claude-sonnet-4.6",
      "model": "llm-agg/forbiddengun/claude",
    },
    "code-reviewer": {
      "mode": "subagent",
      "description": "Code quality review: best practices, security, maintainability, and SOLID/KISS compliance. Read-only. Use after any non-trivial implementation.",
      "model": "ink-gw/openai/chatbot-5.4",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git diff": "allow",
          "git log": "allow",
          "rg *": "allow",
          "grep *": "allow"
        }
      },
      "prompt": "You are a code reviewer. Analyze code for code quality, best practices, SOLID/KISS compliance, potential bugs, edge cases, performance issues, and security concerns. Provide constructive feedback without making direct changes. Always check: naming conventions, error handling, edge cases, null safety, concurrency issues, and dependency direction."
    },
    "tester": {
      "mode": "subagent",
      "description": "Writes and fixes tests. Use for: writing unit/integration/e2e tests, fixing flaky tests, improving coverage. Targets test files only.",
      "model": "ink-gw/deepseek/deepseek-v4-pro",
      "permission": {
        "edit": {
          "*.test.*": "allow",
          "*.spec.*": "allow",
          "*test*/**": "allow",
          "*spec*/**": "allow",
          "*__tests__/**": "allow",
          "vitest.config.*": "allow",
          "jest.config.*": "allow",
          "playwright.config.*": "allow",
          "*": "deny"
        }
      },
      "prompt": "You are a test engineer. Write comprehensive tests following the project's existing test patterns and framework. Cover happy path, edge cases, error conditions, and boundary values. Match existing test style (naming, structure, assertions). Only edit test files and test config."
    },
    "docs-writer": {
      "mode": "subagent",
      "description": "Writes and edits documentation. Use for: README updates, API docs, architecture docs, changelogs, comments. Only edits Markdown and doc files.",
      "model": "llm-agg/forbiddengun/claude",
      "permission": {
        "edit": {
          "*.md": "allow",
          "*.mdx": "allow",
          "*.rst": "allow",
          "docs/**": "allow",
          "README": "allow",
          "CHANGELOG*": "allow",
          "CONTRIBUTING*": "allow",
          "*": "deny"
        },
        "bash": "deny"
      },
      "prompt": "You are a technical writer. Write clear, concise, well-structured documentation. Follow existing documentation style and conventions. Focus on clarity, accuracy, and completeness. Include code examples where helpful. Use proper markdown formatting."
    },
    "security-auditor": {
      "mode": "subagent",
      "description": "Security audit: vulnerability assessment, secret exposure, dependency risks, input validation, auth/authz flaws. Read-only. Use for security reviews and pre-deployment audits.",
      "model": "llm-agg/forbiddengun/claude",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git log": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "npm audit": "allow",
          "pip-audit *": "allow",
          "cargo audit": "allow"
        }
      },
      "prompt": "You are a security auditor. Review code for security vulnerabilities: input validation, authentication/authorization flaws, data exposure, injection risks, dependency vulnerabilities, misconfigurations, and secret leakage. Report findings with severity (critical/high/medium/low) and specific remediation steps. Do not modify files."
    },
    // [Featherless cheapest plan] 32k context, 4 concurrent connections shared across ALL
    // featherless-backed agents below (build, orchestrator, ask, featherless-*). When
    // running a swarm, limit to ≤3 featherless subagents so the orchestrator has a slot.
    "featherless-glm": {
      "mode": "subagent",
      "description": "32k context — swarm perspective agent, GLM-5.2 viewpoint. [Featherless] 4 concurrent connections shared across all featherless-backed agents",
      "model": "featherless/zai-org/GLM-5.2",
    },
    "featherless-deepseek": {
      "mode": "subagent",
      "description": "32k context — swarm perspective agent, DeepSeek V4 Pro viewpoint. [Featherless] 4 concurrent connections shared across all featherless-backed agents",
      "model": "featherless/deepseek-ai/DeepSeek-V4-Pro",
    },
    "featherless-kimi": {
      "mode": "subagent",
      "description": "32k context — swarm perspective agent, Kimi K2.7 Code viewpoint (vision). [Featherless] 4 concurrent connections shared across all featherless-backed agents",
      "model": "featherless/moonshotai/Kimi-K2.7-Code",
    },
    "featherless-minimax": {
      "mode": "subagent",
      "description": "32k context — swarm perspective agent, MiniMax M3 viewpoint. [Featherless] 4 concurrent connections shared across all featherless-backed agents",
      "model": "featherless/MiniMaxAI/MiniMax-M3",
    },
    "featherless-mimo": {
      "mode": "subagent",
      "description": "32k context — swarm perspective agent, MiMo V2.5 viewpoint (multimodal: text, image, audio, video). [Featherless] 4 concurrent connections shared across all featherless-backed agents",
      "model": "featherless/XiaomiMiMo/MiMo-V2.5",
    },
    "featherless-stepfun": {
      "mode": "subagent",
      "description": "32k context — swarm perspective agent, Step-3.7 Flash viewpoint (text, image). [Featherless] 4 concurrent connections shared across all featherless-backed agents",
      "model": "featherless/stepfun-ai/Step-3.7-Flash",
    },
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--browser-url=http://localhost:19222"
      ],
      "enabled": false
    },
    "ado": {
      "type": "local",
      "command": [
        "bash",
        "-lc",
        "npx -y @azure-devops/mcp $ADO_ORG -d core work work-items --authentication envvar"
      ],
      "enabled": false
    },
  },
  "provider": {
    "featherless": {
      "name": "Featherless",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "${FEATHERLESS_BASE_URL}/v1",
      },
      "env": [
        "FEATHERLESS_API_KEY"
      ],
      "models": { // plans limits context to 32k and 256k and concurrent connections to 4 and 8
        "zai-org/GLM-5.2": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 131072,
          },
        },
        "deepseek-ai/DeepSeek-V4-Pro": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 384000,
          },
        },
        "MiniMaxAI/MiniMax-M3": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 512000,
            "output": 128000,
          },
        },
        "moonshotai/Kimi-K2.7-Code": {
          "modalities": {
            "input": [
              "text",
              "image",
              "video",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 262144,
            "output": 262144,
          },
        },
        "XiaomiMiMo/MiMo-V2.5": {
          "modalities": {
            "input": [
              "text",
              "image",
              "audio",
              "video",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1048576,
            "output": 131072,
          },
        },
        "stepfun-ai/Step-3.7-Flash": {
          "modalities": {
            "input": [
              "text",
              "image",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 256000,
            "output": 256000,
          },
        },
      },
    },
    "ink-gw": {
      "name": "INK AI Gateway",
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "${INK_GATEWAY_BASE_URL}/anthropic/v1",
      },
      "env": [
        "INK_GATEWAY_API_KEY"
      ],
      "models": {
        "openai/chatbot-5.4": {
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 16384,
          },
        },
        "openai/chatgpt-5.4-mini": {
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 400000,
            "output": 128000,
          },
        },
        "kCode": {
          "modalities": {
            "input": [
              "text",
              "image",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 92160,
            "output": 32768,
          },
        },
        "deepseek/deepseek-v4-pro": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1048576,
            "output": 384000,
          },
        },
      },
    },
    "llm-agg": {
      "name": "LLM Broker",
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "${LLM_BROKER_BASE_URL}/v1",
      },
      "env": [
        "LLM_BROKER_API_KEY",
      ],
      "models": {
        "forbiddengun/deepseek": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 384000,
          },
        },
        "forbiddengun/mimo": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1048576,
            "output": 131072,
          },
        },
        "forbiddengun/glm": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 131072,
          },
        },
        "forbiddengun/qwen": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 64000,
          },
        },
        "forbiddengun/kimi": {
          "modalities": {
            "input": [
              "text",
              "image",
              "video",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 262144,
            "output": 262144,
          },
        },
        "forbiddengun/minimax": {
          "modalities": {
            "input": [
              "text",
              "image",
              "video",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 512000,
            "output": 128000,
          },
        },
        "forbiddengun/grok": {
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 30000,
          },
        },
        "forbiddengun/mistral": {
          "modalities": {
            "input": [
              "text",
              "image",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 256000,
            "output": 256000,
          },
        },
        "forbiddengun/gpt": {
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf",
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1050000,
            "output": 128000,
          },
        },
        "forbiddengun/claude": {
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf",
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 128000,
          },
        },
      },
    },
  },
  "permission": {
    "bash": {
      "swarminator *": "allow",
      "kilo *": "allow",
      "claude *": "allow",
      "codex *": "allow",
      "gemini *": "allow",
      "cmd *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git fetch *": "allow",
      "git ls-files *": "allow",
      "git show *": "allow",
      "git diff *": "allow",
      "git remote -v *": "allow",
      "git init *": "allow",
      "git check-ignore *": "allow",
      "git checkout *": "allow",
      "git pull *": "allow",
      "git stash list *": "allow",
      "git grep *": "allow",
      "git ls-tree *": "allow",
      "git rev-parse *": "allow",
      "gh repo list *": "allow",
      "gh auth status *": "allow",
      "gh release list *": "allow",
      "gh run list *": "allow",
      "gh run watch *": "allow",
      "gh run view *": "allow",
      "gh pr view *": "allow",
      "gh pr list *": "allow",
      "brew list *": "allow",
      "brew search *": "allow",
      "brew tap-info *": "allow",
      "brew info *": "allow",
      "brew update *": "allow",
      "brew outdated *": "allow",
      "brew upgrade *": "allow",
      "cargo check *": "allow",
      "cargo test *": "allow",
      "rustfmt *": "allow",
      "rustc *": "allow",
      "cargo info *": "allow",
      "cargo doc *": "allow",
      "go mod *": "allow",
      "go get *": "allow",
      "go doc *": "allow",
      "go list *": "allow",
      "go build *": "allow",
      "go run *": "allow",
      "go test *": "allow",
      "go generate *": "allow",
      "go vet *": "allow",
      "gofmt *": "allow",
      "npm list *": "allow",
      "helm version *": "allow",
      "helm lint *": "allow",
      "pwd *": "allow",
      "awk *": "allow",
      "env *": "allow",
      "nl *": "allow",
      "true *": "allow",
      "echo *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "sort *": "allow",
      "wc *": "allow",
      "wait *": "allow",
      "which *": "allow",
      "head *": "allow",
      "cat *": "allow",
      "jq *": "allow",
      "sleep *": "allow",
      "timeout *": "allow",
      "grep *": "allow",
      "basename *": "allow",
      "uuidgen *": "allow",
      "tr *": "allow",
      "tail *": "allow",
      "rg *": "allow",
      "printf *": "allow",
      "command *": "allow",
      "curl *": "allow",
      "test *": "allow",
      "readlink *": "allow",
      "gtimeout *": "allow",
      "stat *": "allow",
      "chmod *": "allow",
      "time *": "allow",
      "read *": "allow",
      "mkdir *": "allow",
      "rmdir *": "allow",
      "ps *": "allow",
      "cmp *": "allow",
      "mktemp *": "allow",
      "lsof *": "allow",
      "pgrep *": "allow",
      "ss *": "allow",
      "fuser *": "allow",
    },
    "recall": {
      "search": "allow"
    },
    "read": {
      "*": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "skill": "allow",
    "todoread": "allow",
    "codesearch": "allow",
    "external_directory": {
      "/tmp/*": "allow",
      "~/.agents/*": "allow",
      "~/.config/kilo/*": "allow",
    },
    "kilo_memory_recall": {
      "*": "allow",
    },
  },
  "experimental": {
    "batch_tool": true,
    "openTelemetry": false
  },
}
