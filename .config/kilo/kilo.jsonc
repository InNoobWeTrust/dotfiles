{
  "$schema": "https://app.kilo.ai/config.json",
  "default_agent": "fastcode",
  "small_model": "kilo/kilo-auto/free",
  "provider": {
    "vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "vllm",
      "options": {
        "baseURL": "${KILO_PROVIDER_VLLM_BASE_URL}"
      },
      "models": {
        "kCode": {
          "options": {
            "variant": "thinking"
          }
        }
      }
    },
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "litellm",
      "options": {
        "baseURL": "${KILO_PROVIDER_LITELLM_BASE_URL}"
      },
      "models": {
        "gpt-5.3-codex": {},
        "gpt-5.4": {},
        "kCode": {},
        "openai/chatbot-5.4-high": {},
        "openai/chatbot-5.4-low": {},
      }
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--browser-url=http://localhost:19222"
      ],
      "enabled": true
    },
  },
  "permission": {
    "bash": {
      "git status *": "allow",
      "git log *": "allow",
      "git fetch *": "allow",
      "git ls-files *": "allow",
      "git show *": "allow",
      "git diff *": "allow",
      "echo *": "allow",
      "ls *": "allow",
      "kilo-swarm *": "allow",
      "~/.local/bin/kilo-swarm *": "allow",
      "kilo *": "allow",
      "find *": "allow",
      "sort *": "allow",
      "wc *": "allow",
      "wait *": "allow",
      "zsh *": "allow",
      "which *": "allow",
      "gemini *": "allow",
      "head *": "allow",
      "cat *": "allow",
      "jq *": "allow",
    },
    "recall": {
      "search": "allow"
    },
    "external_directory": {
      "/tmp/*": "allow",
      "~/.agents/*": "allow",
      "~/.local/bin/*": "allow",
    },
  },
  "instructions": [
    "~/.agents/instructions/agent-instructions.md",
  ],
}
