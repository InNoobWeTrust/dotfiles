{
  "$schema": "https://app.kilo.ai/config.json",
  "small_model": "kilo/kilo-auto/free",
  "default_agent": "autonomous",
  "instructions": [
    "~/.agents/instructions/agent-instructions.md",
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
  },
  "agent": {
    "title": {
      "model": "kilo/kilo-auto/free",
    },
    "summary": {
      "model": "kilo/kilo-auto/free",
    },
    "general": {
      "description": "Read-only general research. USE SPARINGLY: only for vague questions with no specialized subagent match. Prefer explore for codebase nav, plan for design, code for implementation, debug for bugs.",
      "model": "ink-gw/deepseek/deepseek-v4-pro",
      "permission": {
        "edit": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "semantic_search": "allow",
        "codesearch": "allow",
        "skill": "allow",
        "lsp": "allow",
        "external_directory": "allow",
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow",
        "doom_loop": "allow",
        "kilo_memory_save": "allow",
        "kilo_memory_recall": "allow",
        "recall": "allow",
      },
    },
    "explore": {
      "description": "Can only use tools with no side-effect",
      "model": "github-copilot/claude-haiku-4.5",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "semantic_search": "allow",
        "codesearch": "allow",
        "skill": "allow",
        "lsp": "allow",
        "external_directory": "allow",
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow",
        "doom_loop": "allow",
        "kilo_memory_save": "allow",
        "kilo_memory_recall": "allow",
        "recall": "allow",
      },
    },
    "orchestrator": {
      "hidden": true,
      "description": "Deprecated workflow orchestrator for coordinating complex tasks by delegating to specialized agents",
      "model": "llm-agg/forbiddengun/mimo",
    },
    "ask": {
      "description": "A knowledgeable technical assistant focused on answering questions without changing your codebase",
      "model": "github-copilot/claude-haiku-4.5",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "semantic_search": "allow",
        "codesearch": "allow",
        "skill": "allow",
        "lsp": "allow",
        "external_directory": "allow",
        "todowrite": "deny",
        "todoread": "deny",
        "question": "allow",
        "doom_loop": "allow",
        "kilo_memory_save": "deny",
        "kilo_memory_recall": "deny",
        "recall": "allow",
      },
    },
    "plan": {
      "mode": "all",
      "description": "System design, architecture decisions, technical planning, and implementation roadmaps. Use for: design docs, architecture, API contracts, data modeling, tech stack decisions, or planning complex features.",
      "model": "llm-agg/forbiddengun/grok",
      "permission": {
        "edit": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "semantic_search": "allow",
        "codesearch": "allow",
        "skill": "allow",
        "lsp": "allow",
        "external_directory": "allow",
        "todowrite": "deny",
        "todoread": "deny",
        "question": "allow",
        "doom_loop": "allow",
        "kilo_memory_save": "allow",
        "kilo_memory_recall": "allow",
        "recall": "allow",
      },
    },
    "code": {
      "mode": "all",
      "description": "Writes, refactors, and debugs code. Use for: implementing features, fixing bugs, refactoring, writing tests, and any code-level work. Full tool access.",
      "model": "ink-gw/deepseek/deepseek-v4-pro",
      "permission": {
        "edit": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "semantic_search": "allow",
        "codesearch": "allow",
        "skill": "allow",
        "lsp": "allow",
        "external_directory": "allow",
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow",
        "doom_loop": "allow",
        "kilo_memory_save": "allow",
        "kilo_memory_recall": "allow",
        "recall": "allow",
      },
    },
    "debug": {
      "mode": "all",
      "description": "Systematic troubleshooting and root cause analysis. Use for: diagnosing test failures, CI/CD failures, runtime errors, performance issues, and hard-to-reproduce bugs.",
      "model": "llm-agg/forbiddengun/minimax",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "semantic_search": "allow",
        "codesearch": "allow",
        "skill": "allow",
        "lsp": "allow",
        "external_directory": "allow",
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow",
        "doom_loop": "allow",
        "kilo_memory_save": "allow",
        "kilo_memory_recall": "allow",
        "recall": "allow",
      },
    },
    "autonomous": {
      "mode": "primary",
      "description": "Fully autonomous primary agent with unrestricted tool access. Use for unattended end-to-end work, long-running tasks, and AFK automation without approval prompts.",
      "model": "ink-gw/openai/chatbot-5.4",
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "semantic_search": "allow",
        "codesearch": "allow",
        "skill": "allow",
        "lsp": "allow",
        "external_directory": "allow",
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow",
        "doom_loop": "allow",
        "kilo_memory_save": "allow",
        "kilo_memory_recall": "allow",
        "recall": "allow",
      },
      "prompt": "You are a lead operator who orchestrates work through active, proactive delegation.\n\nYour core principle: DELEGATE BY DEFAULT. Do not perform inline code exploration, implementation, testing, debugging, or documentation when specialized agents or delegated subagents can do it.\n\nDivision of responsibility:\n- DELEGATE TO SUBAGENTS: File/code search, writing features/fix patches, running/fixing tests, security audits, code reviews, and deep investigations. Delegating keeps the main thread lean, token-efficient, and focused.\n- RETAIN IN MAIN THREAD: Intent understanding, memory recall, framing subagent tasks, orchestrating parallel/sequential dispatches (`subagent-dispatch`), integrating subagent results, and final acceptance verification.\n\nDelegation failure protocol (apply before giving up or doing it yourself):\n1. DIAGNOSE — determine whether the failure was a bad scope, wrong agent choice, or a genuine task limitation.\n2. RETRY — re-scope the task (tighten context, break it into smaller pieces) and delegate to the same or a different specialized agent.\n3. ESCALATE — if a second attempt also fails, try one more agent (different specialty or a general-purpose one) with a revised prompt.\n4. SELF-EXECUTE (last resort) — only after 2-3 genuine delegation attempts across different agents have all failed, handle the task yourself. Note this fallback explicitly so the user is aware.\n\nWhen in doubt: recall, structure the sub-task, and delegate."
    },
    "code-reviewer": {
      "mode": "subagent",
      "description": "Code quality review: best practices, security, maintainability, and SOLID/KISS compliance. Read-only. Use after any non-trivial implementation.",
      "model": "llm-agg/forbiddengun/gpt",
      "permission": {
        "bash": {
          "*": "deny",
          "git status *": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "rg *": "allow",
          "grep *": "allow"
        },
        "edit": "deny",
      },
      "prompt": "You are a code reviewer. Analyze code for code quality, best practices, SOLID/KISS compliance, potential bugs, edge cases, performance issues, and security concerns. Provide constructive feedback without making direct changes. Always check: naming conventions, error handling, edge cases, null safety, concurrency issues, and dependency direction."
    },
    "tester": {
      "mode": "subagent",
      "description": "Writes and fixes tests. Use for: writing unit/integration/e2e tests, fixing flaky tests, improving coverage. Targets test files only.",
      "model": "ink-gw/deepseek/deepseek-v4-pro",
      "permission": {
        "edit": {
          "*.test.*": "allow",
          "*.spec.*": "allow",
          "*test*/**": "allow",
          "*spec*/**": "allow",
          "*__tests__/**": "allow",
          "vitest.config.*": "allow",
          "jest.config.*": "allow",
          "playwright.config.*": "allow",
          "*": "deny"
        }
      },
      "prompt": "You are a test engineer. Write comprehensive tests following the project's existing test patterns and framework. Cover happy path, edge cases, error conditions, and boundary values. Match existing test style (naming, structure, assertions). Only edit test files and test config."
    },
    "docs-writer": {
      "mode": "subagent",
      "description": "Writes and edits documentation. Use for: README updates, API docs, architecture docs, changelogs, comments. Only edits Markdown and doc files.",
      "model": "github-copilot/claude-haiku-4.5",
      "permission": {
        "edit": {
          "*.md": "allow",
          "*.mdx": "allow",
          "*.rst": "allow",
          "docs/**": "allow",
          "README": "allow",
          "CHANGELOG*": "allow",
          "CONTRIBUTING*": "allow",
          "*": "deny"
        },
        "bash": "deny"
      },
      "prompt": "You are a technical writer. Write clear, concise, well-structured documentation. Follow existing documentation style and conventions. Focus on clarity, accuracy, and completeness. Include code examples where helpful. Use proper markdown formatting."
    },
    "security-auditor": {
      "mode": "subagent",
      "description": "Security audit: vulnerability assessment, secret exposure, dependency risks, input validation, auth/authz flaws. Read-only. Use for security reviews and pre-deployment audits.",
      "model": "llm-agg/forbiddengun/claude",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git status *": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "npm audit *": "allow",
          "pip-audit *": "allow",
          "cargo audit *": "allow",
        }
      },
      "prompt": "You are a security auditor. Review code for security vulnerabilities: input validation, authentication/authorization flaws, data exposure, injection risks, dependency vulnerabilities, misconfigurations, and secret leakage. Report findings with severity (critical/high/medium/low) and specific remediation steps. Do not modify files."
    },
    // [Featherless Plan Concurrency] Total account budget is 4 concurrency units.
    // Concurrency cost depends on model size: Flagship/70B+ models (GLM, DeepSeek, Llama 70B, Kimi, MiniMax, MiMo, Step)
    // cost 4 units/req (max 1 active request). 20B–30B models (Qwen 3.6 27B) cost 2 units/req (max 2 active requests).
    // NOTE: Featherless subagents are slow — avoid using as daily-driver. Use only for multi-perspective tasks (reviewing/brainstorming).
    "featherless-glm": {
      "mode": "subagent",
      "description": "GLM-5.2 viewpoint. Slow performance (avoid using as daily-driver); use only for multi-perspective tasks like reviewing and brainstorming with multiple viewpoints. [Featherless: 4 concurrency units/req — max 1 active request on 4-unit plan]",
      "model": "featherless/zai-org/GLM-5.2",
    },
    "featherless-deepseek": {
      "mode": "subagent",
      "description": "DeepSeek V4 Pro viewpoint. Slow performance (avoid using as daily-driver); use only for multi-perspective tasks like reviewing and brainstorming with multiple viewpoints. [Featherless: 4 concurrency units/req — max 1 active request on 4-unit plan]",
      "model": "featherless/deepseek-ai/DeepSeek-V4-Pro",
    },
    "featherless-kimi": {
      "mode": "subagent",
      "description": "Kimi K2.7 Code viewpoint (vision). Slow performance (avoid using as daily-driver); use only for multi-perspective tasks like reviewing and brainstorming with multiple viewpoints. [Featherless: 4 concurrency units/req — max 1 active request on 4-unit plan]",
      "model": "featherless/moonshotai/Kimi-K2.7-Code",
    },
    "featherless-minimax": {
      "mode": "subagent",
      "description": "MiniMax M3 viewpoint. Slow performance (avoid using as daily-driver); use only for multi-perspective tasks like reviewing and brainstorming with multiple viewpoints. [Featherless: 4 concurrency units/req — max 1 active request on 4-unit plan]",
      "model": "featherless/MiniMaxAI/MiniMax-M3",
    },
    "featherless-mimo": {
      "mode": "subagent",
      "description": "MiMo V2.5 viewpoint (multimodal: text, image, audio, video). Slow performance (avoid using as daily-driver); use only for multi-perspective tasks like reviewing and brainstorming with multiple viewpoints. [Featherless: 4 concurrency units/req — max 1 active request on 4-unit plan]",
      "model": "featherless/XiaomiMiMo/MiMo-V2.5",
    },
    "featherless-stepfun": {
      "mode": "subagent",
      "description": "Step-3.7 Flash viewpoint (text, image). Slow performance (avoid using as daily-driver); use only for multi-perspective tasks like reviewing and brainstorming with multiple viewpoints. [Featherless: 4 concurrency units/req — max 1 active request on 4-unit plan]",
      "model": "featherless/stepfun-ai/Step-3.7-Flash",
    },
    "featherless-qwen": {
      "mode": "subagent",
      "description": "Qwen 3.6 viewpoint. Slow performance (avoid using as daily-driver); use only for multi-perspective tasks like reviewing and brainstorming with multiple viewpoints. [Featherless: 2 concurrency units/req — max 2 active requests on 4-unit plan]",
      "model": "featherless/Qwen/Qwen3.6-27B",
    },
    "featherless-llama": {
      "mode": "subagent",
      "description": "Llama 3.3 70B Instruct viewpoint. Slow performance (avoid using as daily-driver); use only for multi-perspective tasks like reviewing and brainstorming with multiple viewpoints. [Featherless: 4 concurrency units/req — max 1 active request on 4-unit plan]",
      "model": "featherless/unsloth/Llama-3.3-70B-Instruct",
    },
    "featherless-mistral": {
      "mode": "subagent",
      "description": "Mistral Small 3.2 viewpoint. Slow performance (avoid using as daily-driver); use only for multi-perspective tasks like reviewing and brainstorming with multiple viewpoints. [Featherless: 2 concurrency units/req — max 2 active requests on 4-unit plan]",
      "model": "featherless/mistralai/Mistral-Small-3.2-24B-Instruct-2506",
    },
    "featherless-gemma": {
      "mode": "subagent",
      "description": "Gemma 3 27B viewpoint. Slow performance (avoid using as daily-driver); use only for multi-perspective tasks like reviewing and brainstorming with multiple viewpoints. [Featherless: 2 concurrency units/req — max 2 active requests on 4-unit plan]",
      "model": "featherless/unsloth/gemma-3-27b-it",
    },
    "featherless-phi": {
      "mode": "subagent",
      "description": "Phi-4 viewpoint. Slow performance (avoid using as daily-driver); use only for multi-perspective tasks like reviewing and brainstorming with multiple viewpoints. [Featherless: 1 concurrency unit/req — max 4 active requests on 4-unit plan]",
      "model": "featherless/microsoft/phi-4",
    },
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--browser-url=http://localhost:19222"
      ],
      "enabled": false
    },
    "ado": {
      "type": "local",
      "command": [
        "bash",
        "-lc",
        "npx -y @azure-devops/mcp $ADO_ORG -d core work work-items --authentication envvar"
      ],
      "enabled": false
    },
  },
  "provider": {
    "featherless": {
      "name": "Featherless",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "${FEATHERLESS_BASE_URL}/v1",
      },
      "env": [
        "FEATHERLESS_API_KEY"
      ],
      "models": { // Plan concurrency limit: 4 units total (flagship/70B+ cost 4 units/req, 20-30B cost 2 units/req)
