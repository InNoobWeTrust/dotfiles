{
  "$schema": "https://app.kilo.ai/config.json",
  "small_model": "kilo/kilo-auto/free",
  "instructions": [
    "~/.agents/instructions/agent-instructions.md",
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
  },
  "agent": {
    "title": {
      "model": "kilo/kilo-auto/free",
    },
    "summary": {
      "model": "kilo/kilo-auto/free",
    },
    //"compaction": {
    //  "model": "kilo/stepfun/step-3.5-flash:free",
    //},
    "general": {
      "model": "kilo/kilo-auto/free",
    },
    "explore": {
      "model": "kilo/kilo-auto/free",
    },
    "build": {
      "model": "kilo/kilo-auto/free",
    },
    "orchestrator": {
      "hidden": true,
      "model": "kilo/kilo-auto/free",
    },
    "ask": {
      //"model": "kilo/stepfun/step-3.5-flash:free",
      "model": "kilo/deepseek/deepseek-v4-flash:free",
      "options": {
        "reasoningEffort": "high",
      },
    },
    "plan": {
      "model": "github-copilot/gpt-5.4",
      //"model": "openai/gpt-5.4",
      "options": {
        "reasoningEffort": "xhigh",
      },
    },
    "code": {
      "model": "github-copilot/gpt-5.4-mini",
      //"model": "openai/gpt-5.4",
      //"model": "llm-gw/deepseek/deepseek-v4-pro",
      "options": {
        "reasoningEffort": "xhigh",
      },
    },
    "debug": {
      "model": "github-copilot/claude-sonnet-4.6",
      "options": {
        "reasoningEffort": "high",
      },
    },
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--browser-url=http://localhost:19222"
      ],
      "enabled": false
    },
    "ado": {
      "type": "local",
      "command": [
        "bash",
        "-lc",
        "npx -y @azure-devops/mcp $ADO_ORG -d core work work-items --authentication envvar"
      ],
      "enabled": false
    }
  },
  "provider": {
    "oai-gw": {
      "name": "OpenAI Gateway",
      "npm": "@ai-sdk/openai",
      "options": {
        "baseURL": "${LLM_GATEWAY_BASE_URL}/v1",
      },
      "env": [
        "LLM_GATEWAY_API_KEY"
      ],
      "models": {
        "openai/chatbot-5.4": {
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 16384
          },
        },
        "openai/chatgpt-5.4-mini": {
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 400000,
            "output": 8192
          },
        },
      }
    },
    "llm-gw": {
      "name": "Open-weight Models Gateway",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "${LLM_GATEWAY_BASE_URL}/v1",
      },
      "env": [
        "LLM_GATEWAY_API_KEY"
      ],
      "models": {
        "google/gemini-3.5-flash": {
          "modalities": {
            "input": [
              "text",
              "image",
              "video",
              "audio",
              "pdf",
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1048576,
            "output": 65536,
          },
        },
        "google/gemini-3.1-flash-lite": {
          "modalities": {
            "input": [
              "text",
              "image",
              "video",
              "audio",
              "pdf",
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1048576,
            "output": 65536,
          },
        },
        "kCode": {
          "modalities": {
            "input": [
              "text",
              "image",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 92160,
            "output": 32768,
          },
        },
        "deepseek/deepseek-v4-pro": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1048576,
            "output": 384000,
          },
        },
        "deepseek/deepseek-v4-flash": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1048576,
            "output": 384000,
          },
        },
      }
    },
    "llm-agg": {
      "name": "LLM Broker",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "${LLM_BROKER_BASE_URL}/v1",
      },
      "env": [
        "LLM_BROKER_API_KEY",
      ],
      "models": {
        // ── Anthropic Claude ─────────────────────────────────────────
        // claude-sonnet-4-5: SKIP — superseded by 4.6 at same price
        // claude-3-x series: SKIP — all retired early 2026
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 [balanced]",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 900000,
            "output": 16000
          },
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5 [fast]",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 180000,
            "output": 8192
          },
        },
        // ── OpenAI GPT ────────────────────────────────────────────────
        // gpt-5.3-codex: SKIP — no official source; likely fake broker ID
        // gpt-5.2: SKIP — redundant between 5.1 and 5.4
        // gpt-5, gpt-5-mini: SKIP — superseded by 5.1+
        // gpt-4.1, gpt-4.1-mini, gpt-4.1-nano, gpt-4o, gpt-4o-mini: SKIP — RETIRED Feb 13 2026
        "gpt-5.4": {
          "name": "GPT-5.4 [balanced]",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 16384
          },
        },
      },
    },
  },
  "permission": {
    "bash": {
      "swarminator *": "allow",
      "kilo *": "allow",
      "claude *": "allow",
      "codex *": "allow",
      "gemini *": "allow",
      "cmd *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git fetch *": "allow",
      "git ls-files *": "allow",
      "git show *": "allow",
      "git diff *": "allow",
      "git remote -v *": "allow",
      "git init *": "allow",
      "git check-ignore *": "allow",
      "gh repo list *": "allow",
      "git checkout *": "allow",
      "git pull *": "allow",
      "git stash list *": "allow",
      "git grep *": "allow",
      "git ls-tree *": "allow",
      "gh auth status *": "allow",
      "gh release list *": "allow",
      "gh run list *": "allow",
      "gh run watch *": "allow",
      "gh run view *": "allow",
      "gh pr view *": "allow",
      "gh pr list *": "allow",
      "brew list *": "allow",
      "brew search *": "allow",
      "brew tap-info *": "allow",
      "brew info *": "allow",
      "brew update *": "allow",
      "brew outdated *": "allow",
      "brew upgrade *": "allow",
      "cargo check *": "allow",
      "cargo test *": "allow",
      "rustfmt *": "allow",
      "rustc *": "allow",
      "cargo info *": "allow",
      "cargo doc *": "allow",
      "go mod *": "allow",
      "go get *": "allow",
      "go doc *": "allow",
      "go list *": "allow",
      "go build *": "allow",
      "go run *": "allow",
      "go test *": "allow",
      "gofmt *": "allow",
      "go generate *": "allow",
      "go vet *": "allow",
      "npm list *": "allow",
      "helm version *": "allow",
      "helm lint *": "allow",
      "pwd *": "allow",
      "awk *": "allow",
      "env *": "allow",
      "nl *": "allow",
      "true *": "allow",
      "echo *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "sort *": "allow",
      "wc *": "allow",
      "wait *": "allow",
      "which *": "allow",
      "head *": "allow",
      "cat *": "allow",
      "jq *": "allow",
      "sleep *": "allow",
      "timeout *": "allow",
      "grep *": "allow",
      "basename *": "allow",
      "uuidgen *": "allow",
      "tr *": "allow",
      "tail *": "allow",
      "rg *": "allow",
      "printf *": "allow",
      "command *": "allow",
      "curl *": "allow",
      "test *": "allow",
      "readlink *": "allow",
      "gtimeout *": "allow",
      "stat *": "allow",
      "chmod *": "allow",
      "time *": "allow",
      "read *": "allow",
      "mkdir *": "allow",
      "rmdir *": "allow",
      "ps *": "allow",
      "cmp *": "allow",
      "mktemp *": "allow",
      "lsof *": "allow",
      "git rev-parse *": "allow",
    },
    "recall": {
      "search": "allow"
    },
    "read": {
      "*": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "skill": "allow",
    "todoread": "allow",
    "codesearch": "allow",
    "external_directory": {
      "/tmp/*": "allow",
      "~/.agents/*": "allow",
      "~/.config/kilo/*": "allow",
    },
  },
  "experimental": {
    "batch_tool": true,
    "codebase_search": true,
    "semantic_indexing": false,
    "agent_manager_tool": true,
    "openTelemetry": true
  },
}
