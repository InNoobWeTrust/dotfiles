{
  "$schema": "https://app.kilo.ai/config.json",
  "small_model": "kilo/kilo-auto/free",
  "instructions": [
    "~/.agents/instructions/agent-instructions.md",
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
  },
  "agent": {
    "title": {
      "model": "kilo/kilo-auto/free",
    },
    "summary": {
      "model": "kilo/kilo-auto/free",
    },
    //"compaction": {
    //  "model": "kilo/kilo-auto/free",
    //},
    "general": {
      //"model": "github-copilot/claude-sonnet-4.5",
      //"model": "ink-gw/openai/chatgpt-5.4-mini",
      "model": "llm-agg/forbiddengun/deepseek-v4-pro",
    },
    "explore": {
      "model": "github-copilot/claude-haiku-4.5",
      //"model": "ink-gw/openai/chatgpt-5.4-mini",
    },
    "build": {
      "model": "featherless/zai-org/GLM-5.2",
    },
    "orchestrator": {
      "model": "llm-agg/forbiddengun/qwen",
    },
    "ask": {
      "description": "32k context — quick questions, explanations, single-pass answers",
      "model": "featherless/deepseek-ai/DeepSeek-V4-Pro",
    },
    "plan": {
      //"model": "github-copilot/gpt-5.4",
      //"model": "llm-agg/forbiddengun/glm-5.2",
      "model": "ink-gw/openai/chatbot-5.4",
    },
    "code": {
      //"model": "github-copilot/gpt-5.4-mini",
      //"model": "github-copilot/claude-sonnet-4.5",
      "model": "ink-gw/deepseek/deepseek-v4-pro",
      //"model": "llm-agg/forbiddengun/deepseek-v4-pro",
    },
    "debug": {
      //"model": "github-copilot/claude-sonnet-4.6",
      "model": "llm-agg/forbiddengun/glm-5.2",
    },
    // [Featherless cheapest plan] 32k context, 4 concurrent connections shared across ALL
    // featherless-backed agents below (build, orchestrator, ask, featherless-*). When
    // running a swarm, limit to ≤3 featherless subagents so the orchestrator has a slot.
    "featherless-glm": {
      "mode": "subagent",
      "description": "32k context — swarm perspective agent, GLM-5.2 viewpoint. [Featherless] 4 concurrent connections shared across all featherless-backed agents",
      "model": "featherless/zai-org/GLM-5.2",
    },
    "featherless-deepseek": {
      "mode": "subagent",
      "description": "32k context — swarm perspective agent, DeepSeek V4 Pro viewpoint. [Featherless] 4 concurrent connections shared across all featherless-backed agents",
      "model": "featherless/deepseek-ai/DeepSeek-V4-Pro",
    },
    "featherless-kimi": {
      "mode": "subagent",
      "description": "32k context — swarm perspective agent, Kimi K2.7 Code viewpoint (vision). [Featherless] 4 concurrent connections shared across all featherless-backed agents",
      "model": "featherless/moonshotai/Kimi-K2.7-Code",
    },
    "featherless-minimax": {
      "mode": "subagent",
      "description": "32k context — swarm perspective agent, MiniMax M3 viewpoint. [Featherless] 4 concurrent connections shared across all featherless-backed agents",
      "model": "featherless/MiniMaxAI/MiniMax-M3",
    },
    "featherless-mimo": {
      "mode": "subagent",
      "description": "32k context — swarm perspective agent, MiMo V2.5 viewpoint (multimodal: text, image, audio, video). [Featherless] 4 concurrent connections shared across all featherless-backed agents",
      "model": "featherless/XiaomiMiMo/MiMo-V2.5",
    },
    "featherless-stepfun": {
      "mode": "subagent",
      "description": "32k context — swarm perspective agent, Step-3.7 Flash viewpoint (text, image). [Featherless] 4 concurrent connections shared across all featherless-backed agents",
      "model": "featherless/stepfun-ai/Step-3.7-Flash",
    },
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--browser-url=http://localhost:19222"
      ],
      "enabled": false
    },
    "ado": {
      "type": "local",
      "command": [
        "bash",
        "-lc",
        "npx -y @azure-devops/mcp $ADO_ORG -d core work work-items --authentication envvar"
      ],
      "enabled": false
    },
  },
  "provider": {
    "featherless": {
      "name": "Featherless",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "${FEATHERLESS_BASE_URL}/v1",
      },
      "env": [
        "FEATHERLESS_API_KEY"
      ],
      "models": { // plans limits context to 32k and 256k and concurrent connections to 4 and 8
        "zai-org/GLM-5.2": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 131072,
          },
        },
        "deepseek-ai/DeepSeek-V4-Pro": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 384000,
          },
        },
        "MiniMaxAI/MiniMax-M3": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 512000,
            "output": 128000,
          },
        },
        "moonshotai/Kimi-K2.7-Code": {
          "modalities": {
            "input": [
              "text",
              "image",
              "video",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 262144,
            "output": 262144,
          },
        },
        "XiaomiMiMo/MiMo-V2.5": {
          "modalities": {
            "input": [
              "text",
              "image",
              "audio",
              "video",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1048576,
            "output": 131072,
          },
        },
        "stepfun-ai/Step-3.7-Flash": {
          "modalities": {
            "input": [
              "text",
              "image",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 256000,
            "output": 256000,
          },
        },
      },
    },
    "ink-gw": {
      "name": "INK AI Gateway",
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "${INK_GATEWAY_BASE_URL}/anthropic/v1",
      },
      "env": [
        "INK_GATEWAY_API_KEY"
      ],
      "models": {
        "openai/chatbot-5.4": {
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 16384,
          },
        },
        "openai/chatgpt-5.4-mini": {
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 400000,
            "output": 128000,
          },
        },
        "kCode": {
          "modalities": {
            "input": [
              "text",
              "image",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 92160,
            "output": 32768,
          },
        },
        "deepseek/deepseek-v4-pro": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1048576,
            "output": 384000,
          },
        },
      },
    },
    "llm-agg": {
      "name": "LLM Broker",
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "${LLM_BROKER_BASE_URL}/v1",
      },
      "env": [
        "LLM_BROKER_API_KEY",
      ],
      "models": {
        "forbiddengun/deepseek-v4-pro": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 384000,
          },
        },
        "forbiddengun/glm-5.2": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 131072,
          },
        },
        "forbiddengun/qwen": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 64000,
          },
        },
        "forbiddengun/kimi": {
          "modalities": {
            "input": [
              "text",
              "image",
              "video",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 262144,
            "output": 262144,
          },
        },
        "forbiddengun/minimax": {
          "modalities": {
            "input": [
              "text",
              "image",
              "video",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 512000,
            "output": 128000,
          },
        },
        "forbiddengun/grok": {
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 30000,
          },
        },
        "forbiddengun/mistral": {
          "modalities": {
            "input": [
              "text",
              "image",
            ],
            "output": [
              "text",
            ]
          },
          "limit": {
            "context": 256000,
            "output": 256000,
          },
        },
        "forbiddengun/gpt-5.4": {
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf",
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1050000,
            "output": 128000,
          },
        },
        "forbiddengun/gpt-5.5": {
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf",
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1050000,
            "output": 128000,
          },
        },
        "forbiddengun/claude-opus": {
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf",
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 128000,
          },
        },
      },
    },
  },
  "permission": {
    "bash": {
      "swarminator *": "allow",
      "kilo *": "allow",
      "claude *": "allow",
      "codex *": "allow",
      "gemini *": "allow",
      "cmd *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git fetch *": "allow",
      "git ls-files *": "allow",
      "git show *": "allow",
      "git diff *": "allow",
      "git remote -v *": "allow",
      "git init *": "allow",
      "git check-ignore *": "allow",
      "gh repo list *": "allow",
      "git checkout *": "allow",
      "git pull *": "allow",
      "git stash list *": "allow",
      "git grep *": "allow",
      "git ls-tree *": "allow",
      "git rev-parse *": "allow",
      "gh auth status *": "allow",
      "gh release list *": "allow",
      "gh run list *": "allow",
      "gh run watch *": "allow",
      "gh run view *": "allow",
      "gh pr view *": "allow",
      "gh pr list *": "allow",
      "brew list *": "allow",
      "brew search *": "allow",
      "brew tap-info *": "allow",
      "brew info *": "allow",
      "brew update *": "allow",
      "brew outdated *": "allow",
      "brew upgrade *": "allow",
      "cargo check *": "allow",
      "cargo test *": "allow",
      "rustfmt *": "allow",
      "rustc *": "allow",
      "cargo info *": "allow",
      "cargo doc *": "allow",
      "go mod *": "allow",
      "go get *": "allow",
      "go doc *": "allow",
      "go list *": "allow",
      "go build *": "allow",
      "go run *": "allow",
      "go test *": "allow",
      "gofmt *": "allow",
      "go generate *": "allow",
      "go vet *": "allow",
      "npm list *": "allow",
      "helm version *": "allow",
      "helm lint *": "allow",
      "pwd *": "allow",
      "awk *": "allow",
      "env *": "allow",
      "nl *": "allow",
      "true *": "allow",
      "echo *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "sort *": "allow",
      "wc *": "allow",
      "wait *": "allow",
      "which *": "allow",
      "head *": "allow",
      "cat *": "allow",
      "jq *": "allow",
      "sleep *": "allow",
      "timeout *": "allow",
      "grep *": "allow",
      "basename *": "allow",
      "uuidgen *": "allow",
      "tr *": "allow",
      "tail *": "allow",
      "rg *": "allow",
      "printf *": "allow",
      "command *": "allow",
      "curl *": "allow",
      "test *": "allow",
      "readlink *": "allow",
      "gtimeout *": "allow",
      "stat *": "allow",
      "chmod *": "allow",
      "time *": "allow",
      "read *": "allow",
      "mkdir *": "allow",
      "rmdir *": "allow",
      "ps *": "allow",
      "cmp *": "allow",
      "mktemp *": "allow",
      "lsof *": "allow",
      "pgrep *": "allow",
      "ss *": "allow",
      "fuser *": "allow",
    },
    "recall": {
      "search": "allow"
    },
    "read": {
      "*": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "skill": "allow",
    "todoread": "allow",
    "codesearch": "allow",
    "external_directory": {
      "/tmp/*": "allow",
      "~/.agents/*": "allow",
      "~/.config/kilo/*": "allow",
    },
  },
  "experimental": {
    "batch_tool": true,
    "openTelemetry": false
  },
}
