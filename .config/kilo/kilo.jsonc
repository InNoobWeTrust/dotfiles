{
  "$schema": "https://app.kilo.ai/config.json",
  "default_agent": "orchestrator",
  "small_model": "kilo/kilo-auto/free",
  "provider": {
    "vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "vllm",
      "options": {
        "baseURL": "${KILO_PROVIDER_VLLM_BASE_URL}"
      },
      "models": {
        "kCode": {
          "options": {
            "variant": "thinking"
          }
        }
      }
    },
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "litellm",
      "options": {
        "baseURL": "${KILO_PROVIDER_LITELLM_BASE_URL}"
      },
      "models": {
        "all-proxy-models": {},
        "qwen/qwen3.6-plus": {
          "options": {
            "variant": "thinking",
          }
        },
        "openai/chatbot-5.3-codex": {},
        "openai/chatbot-5.4": {
          "options": {
            "reasoning_effort": "high",
          }
        },
        "openai/chatbot-5.3-instant": {},
        "openai/chatbot-5.4-pro": {},
        "openai/chatbot-5.3-chat-latest": {},
        "MiniMax-M2.7-highspeed": {
          "options": {
            "reasoning_effort": "xhigh",
          }
        },
        "openai/chatbot-5.3-codex-spark": {},
        "kilo-auto/free": {},
        "kilo-auto/balanced": {
          "options": {
            "reasoning_effort": "high"
          }
        },
      }
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--browser-url=http://localhost:19222"
      ],
      "enabled": true
    },
  },
  "permission": {
    "git status*": "allow",
    "git diff*": "allow",
    "git log*": "allow",
    "git show*": "allow",
    "git branch*": "allow",
    "git remote*": "allow",
    "git rev-parse*": "allow",
    "git ls-files*": "allow",
    "git fetch*": "ask",
    "git add*": "ask",
    "git commit*": "ask",
    "git push*": "ask",
    "git reset*": "ask",
    "git restore*": "ask",
    "git checkout*": "ask",
    "git switch*": "ask",
    "git merge*": "ask",
    "git rebase*": "ask",
    "git cherry-pick*": "ask",
    "git revert*": "ask",
    "git stash*": "ask",
    "git clean*": "ask",
    "git tag*": "ask",
    "git submodule*": "ask",
    "gh pr create*": "ask",
    "gh pr merge*": "ask",
    "gh repo sync*": "ask",
    "sh -c *git *": "ask",
    "bash -c *git *": "ask",
    "zsh -c *git *": "ask",
    "bash": {
      "git status *": "allow",
      "git log *": "allow",
      "git fetch *": "allow",
      "git ls-files *": "allow",
      "git show *": "allow",
      "git diff *": "allow",
      "echo *": "allow",
      "ls *": "allow",
      "kilo-swarm *": "allow",
      "~/.local/bin/kilo-swarm *": "allow",
      "kilo *": "allow",
      "find *": "allow",
      "sort *": "allow",
      "wc *": "allow",
      "wait *": "allow",
      "zsh *": "allow",
    },
    "recall": {
      "search": "allow"
    },
    "external_directory": {
      "/tmp/*": "allow",
      "~/.agents/*": "allow",
      "~/.local/bin/*": "allow",    },
  },
  "instructions": [
    "~/.agents/instructions/agent-instructions.md",
  ],
}
