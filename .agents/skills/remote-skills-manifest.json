{
  "$schema": "Remote skills manifest — maps local skill directories to their upstream GitHub sources",
  "remotes": {
    
  },
  "data_sources": {
    "ui-ux": [
      {
        "name": "ui-ux-pro-max",
        "owner": "nextlevelbuilder",
        "repo": "ui-ux-pro-max-skill",
        "path": "cli/assets/data",
        "branch": "main",
        "cache_env": "UI_UX_CACHE",
        "default_cache": ".cache/ui-ux-skill"
      }
    ],
    "video-production": [
      {
        "name": "story-to-animation-2026",
        "owner": "ducloc99",
        "repo": "story-to-animation-2026",
        "path": "skills",
        "branch": "main",
        "cache_env": "VIDEO_PROD_CACHE",
        "default_cache": ".cache/video-production-skill"
      }
    ]
  }
}
