# Directories and files that should stay in the repo, not be stowed to $HOME.
# One regex pattern per line (anchored to basename by stow).

# Repo management
bootstrap\.sh
\.stow-ignore

# Non-dotfile project dirs
\.innoobwetrust

# Hermes secrets — never stow the live .env (use .env.example)
\.hermes/\.env$

# Misc
.DS_Store
