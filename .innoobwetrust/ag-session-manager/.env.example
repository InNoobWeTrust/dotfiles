# Port for the session manager server
PORT=3000

# Network interfaces to bind to (auto = auto-detect LAN + Tailscale)
BIND_INTERFACES=auto

# Optional auth token (leave empty to rely on network-level security)
AUTH_TOKEN=

# Comma-separated root directories for the directory browser
# Defaults to $HOME if not set
BROWSE_ROOTS=

# Antigravity binary name (auto-detected if on PATH)
ANTIGRAVITY_BIN=

# Debug port range start (sessions use ports START to START+99)
CDP_PORT_START=9000
