#!/usr/bin/env bash
# kilo-swarm — Single-pass swarm node runner (raw pass-through proxy)
#
# Runs one agent invocation (kilo or gemini-cli) and passes raw output through.
# The synthesizer handles all parsing, extraction, and consensus building.
#
# Engine selection is automatic based on model ID:
#   - Models matching ^(kilo/)?google/ or ^gemini/ → gemini-cli
#   - All other models → kilo run
#
# For gemini engine, the model name is normalised:
#   kilo/google/<name>  →  <name>   (strip prefix)
#   google/<name>       →  <name>   (strip prefix)
#   gemini/<name>       →  <name>   (strip prefix)
#   gemini-*            →  used as-is
#
# Usage:
#   echo "input" | kilo-swarm -m MODEL -p PERSONA
#   kilo-swarm -m MODEL -p PERSONA < input_file
#
# Options:
#   -m MODEL      model to use (required)
#   -p PERSONA    persona/instruction string passed as the user message (required)
#   -t SECONDS    timeout for the agent run call (default: 0 = disabled)
#   --dry-run     print the command without executing
#   --verbose     emit extra debug info to stderr
#   -h            show this help
#
# Output: raw text from agent to stdout; logs to stderr
# Exit:   0 = success (even if output is empty/note to synthesizer)
#         2 = invocation failure (orchestrator: retry this node)

set -euo pipefail

MODEL=""
PERSONA=""
DRY_RUN=false
VERBOSE=false
TIMEOUT=0

usage() {
  sed -n '3,22p' "$0" | sed 's/^# //' | sed 's/^#//'
  exit 0
}

log()  { printf '[kilo-swarm] %s\n' "$*" >&2; }
vlog() { if [[ "$VERBOSE" == "true" ]]; then printf '[kilo-swarm:verbose] %s\n' "$*" >&2; fi; }

# Detect engine from model ID.
# Returns "gemini" if the model should be run via gemini-cli, else "kilo".
detect_engine() {
  local model="$1"
  case "$model" in
    kilo/google/*|google/*|gemini/*|gemini-*)
      echo "gemini" ;;
    *)
      echo "kilo" ;;
  esac
}

# Strip provider prefix from a model ID to get the bare name for gemini-cli.
strip_gemini_prefix() {
  local model="$1"
  model="${model#kilo/google/}"
  model="${model#google/}"
  model="${model#gemini/}"
  echo "$model"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -m) MODEL="$2";       shift 2 ;;
    -p) PERSONA="$2";     shift 2 ;;
    -t) TIMEOUT="$2";     shift 2 ;;
    --dry-run)  DRY_RUN=true;  shift ;;
    --verbose)  VERBOSE=true;  shift ;;
    -h|--help)  usage ;;
    *) log "Unknown option: $1"; exit 1 ;;
  esac
done

[[ -z "$MODEL" ]]   && { log "ERROR: -m MODEL is required"; exit 1; }
[[ -z "$PERSONA" ]] && { log "ERROR: -p PERSONA is required"; exit 1; }

# Write stdin to a tmpfile so both engines can reference it by path
TMP_INPUT=""
TMP_STDERR=""
TMP_STDOUT=""

cleanup() {
  [[ -n "$TMP_INPUT" ]]  && rm -f "$TMP_INPUT"
  [[ -n "$TMP_STDERR" ]] && rm -f "$TMP_STDERR"
  [[ -n "$TMP_STDOUT" ]] && rm -f "$TMP_STDOUT"
}

trap cleanup EXIT

# In dry-run mode stdin is optional — skip reading it
if [[ "$DRY_RUN" == "true" ]]; then
  TMP_INPUT=$(mktemp)
  if ! [[ -t 0 ]]; then cat > "$TMP_INPUT"; fi
else
  # Require piped stdin for real runs
  [[ -t 0 ]] && { log "ERROR: no stdin — pipe input to kilo-swarm"; exit 1; }
  TMP_INPUT=$(mktemp)
  cat > "$TMP_INPUT"
  [[ -s "$TMP_INPUT" ]] || { log "ERROR: stdin was empty"; exit 1; }
fi

# Build the full message: input path reference + swarm-node instructions + persona
SWARM_NODE_MSG="Input document is at: ${TMP_INPUT}
Please read that file first, then follow the persona instructions below.

## Persona Instructions

${PERSONA}"

# Determine engine and build command array
ENGINE=$(detect_engine "$MODEL")
vlog "engine=$ENGINE  model=$MODEL"

if [[ "$ENGINE" == "gemini" ]]; then
  BARE_MODEL=$(strip_gemini_prefix "$MODEL")
  # gemini-cli: inline the input content into the prompt.
  # Guard against large inputs that could exceed ARG_MAX (~2MB on Linux).
  INPUT_SIZE=$(wc -c < "$TMP_INPUT" | tr -d ' ') || { log "ERROR: wc -c failed on input file"; exit 2; }
  if ! [[ "$INPUT_SIZE" =~ ^[0-9]+$ ]]; then log "ERROR: wc -c returned non-numeric value: $INPUT_SIZE"; exit 2; fi
  MAX_INLINE=1048576  # 1 MiB
  if [[ "$INPUT_SIZE" -gt "$MAX_INLINE" ]]; then
    log "ERROR: gemini engine input too large (${INPUT_SIZE} bytes > ${MAX_INLINE} limit); use a kilo model for large inputs"
    exit 2
  fi
  GEMINI_MSG="You are a focused, single-purpose analysis node in a multi-agent pipeline.

## Core Rules

1. Follow the persona instructions below exactly.
2. Provide thorough, well-structured output with all relevant information and recommendations.
3. Use web search when the persona explicitly requests it.
4. Be specific and detailed — the synthesizer builds consensus from multiple node outputs.
5. Never modify files or run shell commands.

## Input

$(cat "$TMP_INPUT")

## Persona Instructions

${PERSONA}"
  AGENT_CMD=(gemini -y -m "$BARE_MODEL" -p "$GEMINI_MSG")
else
  AGENT_CMD=(kilo run --auto --model "$MODEL" --agent swarm-node "$SWARM_NODE_MSG")
fi

# Build command array (with optional timeout wrapper)
if [[ "$TIMEOUT" -gt 0 ]]; then
  if command -v timeout >/dev/null 2>&1; then
    AGENT_CMD=(timeout "$TIMEOUT" "${AGENT_CMD[@]}")
  elif command -v gtimeout >/dev/null 2>&1; then
    AGENT_CMD=(gtimeout "$TIMEOUT" "${AGENT_CMD[@]}")
  else
    log "ERROR: -t specified but neither 'timeout' nor 'gtimeout' found; cannot enforce timeout"
    exit 2
  fi
fi

if [[ "$DRY_RUN" == "true" ]]; then
  persona_preview="${PERSONA:0:120}"
  [[ "${#PERSONA}" -gt 120 ]] && persona_preview+="..."
  log "DRY-RUN engine: $ENGINE"
  log "DRY-RUN cmd : ${AGENT_CMD[*]}"
  log "DRY-RUN persona (${#PERSONA} chars): $persona_preview"
  exit 0
fi

vlog "model=$MODEL  engine=$ENGINE  input=$TMP_INPUT  persona_len=${#PERSONA}  timeout=${TIMEOUT}s"

# Run agent — capture stdout and stderr
TMP_STDERR=$(mktemp)
TMP_STDOUT=$(mktemp)
agent_status=0

"${AGENT_CMD[@]}" >"$TMP_STDOUT" 2>"$TMP_STDERR" || agent_status=$?

if [[ $agent_status -ne 0 ]]; then
  if [[ $agent_status -eq 124 ]]; then
    log "ERROR: agent run timed out after ${TIMEOUT}s"
  elif [[ -s "$TMP_STDERR" ]]; then
    log "WARN: agent run exited with status $agent_status"
    cat "$TMP_STDERR" >&2
  else
    log "WARN: agent run exited with status $agent_status (no stderr output)"
  fi
  exit 2
fi

# Pass raw output through — synthesizer handles all parsing
cat "$TMP_STDOUT"
exit 0
